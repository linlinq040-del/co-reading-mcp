{
  "name": "co-reading-mcp",
  "version": "0.1.0",
  "description": "A local co-reading MCP server for chunked books, reading progress, search, and margin annotations.",
  "type": "module",
  "author": "GPT, Claude, and Koshi",
  "files": [
    "src",
    "public",
    "scripts/import_epub.py",
    "scripts/import_text.py",
    "scripts/smoke.mjs",
    "scripts/card-smoke.mjs",
    "docs",
    "data.example",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "co-reading-mcp": "./src/server.js",
    "co-reading-reader": "./src/http.js",
    "co-reading-sse": "./src/server-sse.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "reader": "node src/http.js",
    "start:sse": "node src/server-sse.js",
    "smoke": "node scripts/smoke.mjs",
    "smoke:cards": "node scripts/card-smoke.mjs",
    "import:text": "python3 scripts/import_text.py",
    "import:epub": "python3 scripts/import_epub.py",
    "install:card-renderer": "npx playwright install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "reading",
    "annotations",
    "epub",
    "claude"
  ],
  "license": "MIT"
}
